#!/usr/bin/env bash
# pstack-review-log — atomically log a review result
# Usage: pstack-review-log '{"skill":"...","timestamp":"...","status":"..."}'
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/pstack-slug" 2>/dev/null)"
PSTACK_HOME="${PSTACK_HOME:-$HOME/.pstack}"
mkdir -p "$PSTACK_HOME/projects/$SLUG"

# Validate: input must be parseable JSON (reject malformed or injection attempts)
INPUT="$1"
if ! printf '%s' "$INPUT" | bun -e "JSON.parse(await Bun.stdin.text())" 2>/dev/null; then
  # Not valid JSON — refuse to append
  echo "pstack-review-log: invalid JSON, skipping" >&2
  exit 1
fi

echo "$INPUT" >> "$PSTACK_HOME/projects/$SLUG/$BRANCH-reviews.jsonl"
