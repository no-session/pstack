#!/usr/bin/env bash
# pstack-review-read — read review log and config for dashboard
# Usage: pstack-review-read
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/pstack-slug" 2>/dev/null)"
PSTACK_HOME="${PSTACK_HOME:-$HOME/.pstack}"
cat "$PSTACK_HOME/projects/$SLUG/$BRANCH-reviews.jsonl" 2>/dev/null || echo "NO_REVIEWS"
echo "---CONFIG---"
"$SCRIPT_DIR/pstack-config" get skip_eng_review 2>/dev/null || echo "false"
echo "---HEAD---"
git rev-parse --short HEAD 2>/dev/null || echo "unknown"
